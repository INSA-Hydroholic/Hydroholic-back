// BASE CONFIG
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// 1. USER
// ---------------------------------------------------------
model User {
  id                      Int           @id @default(autoincrement())
  email                   String        @unique
  password_hash           String
  surname                 String        // Correspond à 'nom'
  name                    String        // Correspond à 'prenom'
  username                String        @unique
  phone                   String?
  age                     Int?
  sex                     String?
  weight                  Float?
  height                  Float?
  city                    String?
  avatar_url              String?
  num_intense_activities  Int           @default(0)
  num_moderate_activities Int           @default(0)
  biography               String?       @db.Text
  daily_goal              Int           @default(2000)
  room                    String?
  role                    String        @default("USER")
  
  // 1-1 Relationship with Device (ESP32)
  esp32                   Device?       @relation(fields: [esp32Id], references: [id])
  esp32Id                 Int?          @unique

  // Relationship with Organization
  organizationId          Int?
  organization            Organization? @relation(fields: [organizationId], references: [id])

  created_at              DateTime      @default(now())
  updated_at              DateTime      @updatedAt

  // Inverse relantionships
  hydrationLogs           HydrationLog[]
  createdChallenges       Challenge[]   @relation("Creator")
  participations          ChallengeParticipant[]
  sentRequests            Relationship[] @relation("Requester")
  receivedRequests        Relationship[] @relation("Receiver")
  goals                   Goal[]
  alerts                  AlertLog[]
}

// ---------------------------------------------------------
// 2. DEVICES (ESP32s)
// ---------------------------------------------------------
model Device {
  id              Int           @id @default(autoincrement())
  macAddress      String        @unique
  batteryLevel              Int?
  batteryMeasuredAt         DateTime?
  
  // Reverse 1-1 relationship with User
  user            User?
  
  organizationId  Int?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
}

// ---------------------------------------------------------
// 3. ESTABLISHMENT
// ---------------------------------------------------------
model Organization {
  id          Int       @id @default(autoincrement())
  name        String
  adresse     String
  type        String    // 'EHPAD', etc.
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  users       User[]
  inventory   Device[]
}

// ---------------------------------------------------------
// 4. RELATIONSHIP (Friends)
// ---------------------------------------------------------
model Relationship {
  requesterID Int
  receiverID  Int
  status      String    // 'PENDING', 'ACCEPTED', etc.
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  requester   User      @relation("Requester", fields: [requesterID], references: [id])
  receiver    User      @relation("Receiver", fields: [receiverID], references: [id])

  @@id([requesterID, receiverID])
}

// ---------------------------------------------------------
// 5. HYDRATION LOG
// ---------------------------------------------------------
model HydrationLog {
  id            Int      @id @default(autoincrement())
  userID        Int
  weight        Float
  source        String   @default("hydrobase")
  measured_at   DateTime @default(now())
  submitted_at  DateTime @default(now())

  user          User     @relation(fields: [userID], references: [id])
}

// ---------------------------------------------------------
// 6. CHALLENGE
// ---------------------------------------------------------
model Challenge {
  id              Int      @id @default(autoincrement())
  creator_id      Int
  title           String
  description     String?  @db.Text
  start_date      DateTime
  end_date        DateTime
  status          String
  challenge_type  String
  objective_ml    Int

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  creator         User     @relation("Creator", fields: [creator_id], references: [id])
  participants    ChallengeParticipant[]
}

// ---------------------------------------------------------
// 7. CHALLENGE PARTICIPANTS
// ---------------------------------------------------------
model ChallengeParticipant {
  id            Int       @id @default(autoincrement())
  challengeID   Int
  userID        Int
  joined_date   DateTime  @default(now())
  progress_ml   Int       @default(0)
  status        String

  challenge     Challenge @relation(fields: [challengeID], references: [id])
  user          User      @relation(fields: [userID], references: [id])
}

// ---------------------------------------------------------
// 8. GOAL (Objectives)
// ---------------------------------------------------------
model Goal {
  id            Int       @id @default(autoincrement())
  userID        Int
  goal_type_id  Int
  value         Float
  start_date    DateTime
  end_date      DateTime
  status        String

  user          User      @relation(fields: [userID], references: [id])
  goalType      GoalType  @relation(fields: [goal_type_id], references: [id])
}

// ---------------------------------------------------------
// 9. OBJETIVE TYPE
// ---------------------------------------------------------
model GoalType {
  id        Int      @id @default(autoincrement())
  unit      String   // 'ml'
  duration  String   // 'daily', 'weekly'
  goals     Goal[]
}

// ---------------------------------------------------------
// 10. ALERTS
// ---------------------------------------------------------
model AlertLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  message     String
  severity    String   // 'RED', 'YELLOW'
  isResolved  Boolean  @default(false)
  created_at  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}